# Copia este archivo como .env y completa los valores reales.
# NUNCA commitees .env al repositorio.

# Token personal de GitHub con permisos para commitear al repo destino.
GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Repositorio destino donde se subirá el CSV (formato: usuario/repo).
GITHUB_REPO=1bryanvalenzuela/Comparador-Supermercados-Chile

# Rama destino.
GITHUB_BRANCH=main

# Nombre del archivo CSV dentro del repo.
GITHUB_CSV_PATH=Listado-Supermercado.csv

# (Opcional) Lista de proxies HTTP separados por coma para rotación.
# Ejemplo: http://user:pass@host:port,http://host2:port
PROXIES=
